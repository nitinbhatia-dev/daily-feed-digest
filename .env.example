# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Twitter / X ────────────────────────────────────────────────────────────
# Get from: https://developer.twitter.com → Project → Keys & Tokens
TWITTER_ENABLED=true
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAA...
TWITTER_QUERY=#AINews OR #LLM OR from:sama
TWITTER_MAX_RESULTS=20

# ── GitHub ─────────────────────────────────────────────────────────────────
# Token optional for public repos. Generate at: https://github.com/settings/tokens
GITHUB_ENABLED=true
GITHUB_TOKEN=ghp_...
GITHUB_REPOS=vercel/next.js,openai/openai-python,anthropics/anthropic-sdk-python
GITHUB_FETCH_TYPE=commits   # commits | issues | pulls | releases
GITHUB_PER_REPO=5

# ── Slack ──────────────────────────────────────────────────────────────────
# Bot token from: https://api.slack.com/apps → OAuth & Permissions
# Required scopes: channels:history, channels:read
SLACK_ENABLED=true
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_IDS=C01234ABCDE,C09876ZYXWV
SLACK_LOOKBACK_HOURS=24

# ── Reddit ─────────────────────────────────────────────────────────────────
# Create a "script" app at: https://www.reddit.com/prefs/apps
REDDIT_ENABLED=true
REDDIT_CLIENT_ID=abc123XYZ
REDDIT_CLIENT_SECRET=aBcDeFgHiJkLmNoP
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_SUBREDDITS=MachineLearning,programming,india
REDDIT_SORT=hot   # hot | new | top
REDDIT_LIMIT=10

# ── Output ─────────────────────────────────────────────────────────────────
# Optional: save digest to a file (.md, .json, or .txt)
OUTPUT_FILE=digest.md

# ── Summary instructions ───────────────────────────────────────────────────
DIGEST_INSTRUCTIONS=Summarize the key stories, trends, and notable discussions. Group by theme where possible. Flag anything urgent or time-sensitive. Keep it concise — 3 to 5 bullet points per source.
